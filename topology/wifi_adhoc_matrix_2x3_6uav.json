{
  "schema_version": 2,
  "scenario_id": "wifi_adhoc_matrix_2x3_6uav_v1",
  "description": "UCS mesh stage-4 topology: Linux-visible L2 mesh with BMv2 inline dataplanes, isolated ns-3 endpoint-pair wireless links, and gimbal-camera UAV payloads. Observation traffic stays on Docker 172.x eth0; experiment traffic uses one visible eth1 per UAV. links[] and mesh_links[] are independent logical wireless links with per-pair loss, queueing, and ARQ state; they do not share an ad-hoc Wi-Fi contention domain.",
  "globals": {
    "fabric_mode": "l2_link_mesh",
    "gs_id": "gs",
    "tap_left": "tap-gs",
    "exp_if": "eth1",
    "time_file": "/tmp/ucs_mesh_sim_time.txt",
    "gz_partition": "ucs",
    "px4_gz_world_name": "ucs_obstacle_field",
    "world_sdf": "px4_gazebo/worlds/ucs_obstacle_field.sdf",
    "px4_sim_model_name": "gz_x500_gimbal",
    "tick": "4ms",
    "pcap": false,
    "verbose": false,
    "stop_time": 0,
    "gs_pose": {
      "x": 0.0,
      "y": 0.0,
      "z": 1.5
    },
    "observation_net": {
      "interface": "eth0",
      "address_family": "docker_bridge_172"
    },
    "experiment_net": {
      "mode": "l2_link_mesh",
      "address_rule": "10.10.<cluster_id>.<node_id>/24",
      "reserved_cluster_id": 0,
      "uav_cluster_ids": [
        1,
        2
      ],
      "route_policy": "linux_onlink_peer_routes",
      "impairment_policy": "ns3_pairwise_links",
      "gs_ips": [
        "10.10.0.254/24"
      ],
      "peer_route_scope": "link",
      "ns3_role": "isolated_pairwise_l2_impairment_no_ip_routing"
    },
    "business_flows": {
      "control": {
        "enabled": true,
        "network": "experiment",
        "protocol": "udp",
        "direction": "gs_to_uav_and_uav_to_gs",
        "port_source": "instances[].qgc_port",
        "qgc": {
          "enabled": true,
          "port_source": "instances[].qgc_port",
          "local_port_rule": "18570 + instances[].px4_instance",
          "remote_ip": "ground_station.exp_ip",
          "remote_port": 14550,
          "rate_bytes_per_sec": 20000,
          "traffic_class": "control"
        },
        "mavsdk": {
          "enabled": true,
          "uav_local_port_base": 18600,
          "uav_local_port_rule": "18600 + instances[].idx",
          "gs_remote_port_base": 14600,
          "gs_remote_port_rule": "14600 + instances[].idx",
          "remote_ip": "ground_station.exp_ip",
          "rate_bytes_per_sec": 20000,
          "px4_default_offboard_rate_bytes_per_sec": 20000,
          "mavsdk_url_rule": "udpin://0.0.0.0:<gs_remote_port>",
          "runner": "control/control_up.sh",
          "traffic_class": "control"
        },
        "traffic_class": "control",
        "latency_sensitive": true
      },
      "video": {
        "enabled": true,
        "role": "sub",
        "label": "sub",
        "network": "experiment",
        "protocol": "udp",
        "encoding": "rtp_h264",
        "direction": "uav_to_gs",
        "port_base": 5600,
        "port_rule": "5600 + instances[].idx",
        "traffic_class": "video",
        "source": "Gazebo x500_gimbal camera topic, downscaled for dashboard preview",
        "source_resolution": "1920x1080",
        "default_resolution": "960x540",
        "default_fps": 30,
        "default_bitrate_kbps": 1500,
        "bridge": {
          "runner": "video/run_rtp_camera_flow.sh",
          "sender_namespace": "instances[].container_name network namespace",
          "source_ip": "instances[].exp_ip",
          "destination_ip": "ground_station.exp_ip",
          "camera_topic_rule": "/world/<px4_gz_world_name>/model/<instances[].model_name>/link/<payload.camera_link>/sensor/<payload.camera_sensor>/image"
        }
      },
      "video_main": {
        "enabled": true,
        "role": "main",
        "label": "main",
        "network": "experiment",
        "protocol": "udp",
        "encoding": "rtp_h264",
        "direction": "uav_to_gs",
        "port_base": 5700,
        "port_rule": "5700 + instances[].idx",
        "traffic_class": "video_main",
        "source": "Gazebo x500_gimbal camera topic",
        "source_resolution": "1920x1080",
        "default_resolution": "1920x1080",
        "default_fps": 30,
        "default_bitrate_kbps": 8000,
        "bridge": {
          "runner": "video/run_rtp_camera_flow.sh",
          "sender_namespace": "instances[].container_name network namespace",
          "source_ip": "instances[].exp_ip",
          "destination_ip": "ground_station.exp_ip",
          "camera_topic_rule": "/world/<px4_gz_world_name>/model/<instances[].model_name>/link/<payload.camera_link>/sensor/<payload.camera_sensor>/image"
        }
      }
    },
    "payload": {
      "profile": "camera_gimbal",
      "px4_airframe": "gz_x500_gimbal",
      "gazebo_model": "x500_gimbal",
      "camera_link": "camera_link",
      "camera_sensor": "camera",
      "gimbal_command_topics": [
        "command/gimbal_roll",
        "command/gimbal_pitch",
        "command/gimbal_yaw"
      ]
    },
      "link_simulation": {
        "enabled": true,
        "model": "large_small_fading_v1",
        "link_error_model": "receiver_sensitivity_bler_v1",
        "rx_sensitivity_dbm": -92.0,
        "rx_loss_full_dbm": -96.0,
        "noise_floor_dbm": -96.0,
        "packet_error_bytes": 1200.0,
        "packet_size_scaling_enabled": true,
        "packet_error_rate_cap": 1.0,
        "packet_error_smoothing_tau_s": 0.15,
        "mac_medium_access": "pairwise_serial_arq_v1",
        "mac_data_rate": "20Mbps",
        "mac_queue_limit_packets": 512,
        "mac_retry_enabled": true,
        "mac_retry_max_retries": 7,
        "mac_retry_slot_time": "1ms",
        "mac_retry_jitter_max": "2ms",
        "mac_retry_broadcast": false,
        "frequency_hz": 5180000000.0,
      "large_scale": {
        "path_loss": {
          "model": "ns3::LogDistancePropagationLossModel",
          "exponent": 2.15,
          "reference_distance_m": 1.0
        },
        "shadow_fading": {
          "enabled": true,
          "stddev_db": 4.0,
          "correlation_distance_m": 25.0
        },
        "obstruction": {
          "enabled": true,
          "base_loss_db": 6.0,
          "loss_per_hit_db": 18.0,
          "loss_per_meter_db": 1.5,
          "max_loss_db": 35.0,
          "min_intersection_m": 0.25,
          "diffraction_margin_m": 2.0,
          "diffraction_loss_db": 4.0,
          "smoothing_tau_s": 0.25,
          "edge_ramp_m": 3.0
        }
      },
      "small_scale": {
        "multipath": {
          "enabled": true,
          "model": "ns3::NakagamiPropagationLossModel",
          "min_relative_speed_mps": 0.1,
          "coherence_distance_m": 2.0,
          "coherence_time_s": 0.75,
          "max_loss_db": 5.0,
          "max_gain_db": 2.0,
          "smoothing_tau_s": 0.3,
          "distance1_m": 80.0,
          "distance2_m": 200.0,
          "m0": 8.0,
          "m1": 6.0,
          "m2": 4.0
        },
        "doppler": {
          "enabled": false,
          "model": "ns3::JakesPropagationLossModel",
          "min_relative_speed_mps": 0.1,
          "doppler_frequency_hz": 80.0,
          "oscillators": 20
        }
      },
      "tx_power_dbm": 20.0,
      "wifi": {
        "standard": "802.11a",
        "mac": "ns3::AdhocWifiMac",
        "rate_manager": "ns3::ConstantRateWifiManager",
        "data_mode": "OfdmRate54Mbps",
        "control_mode": "OfdmRate6Mbps",
        "tap_bridge_mode": "UseBridge",
        "channel_settings": "{36, 20, BAND_5GHZ, 0}",
