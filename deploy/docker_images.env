# Fixed Docker image set for the 2026-06-25 UCS BMv2 mesh deployment.
#
# Export these on the working machine and import them on the server with
# docker load. The server should not build UAV/Gazebo/BMv2/P4 images during
# deployment.

UCS_IMAGE_SET_DATE=20260625

# Required for normal runtime.
UCS_RUNTIME_IMAGE_LIST="ucs-uav-base-gz-bmv2:20260625 ucs-gazebo-runtime:20260625 ucs-p4runtime-sh:20260625"

# Optional build/development images. Not required on the server when prebuilt
# P4 artifacts and runtime images are copied with the repo/image tarball.
UCS_BUILD_IMAGE_LIST="ucs-uav-base-gz:20260625 ucs-p4c:20260625 ucs-bmv2-runtime:20260625 ucs-p4-compiler:20260625"

# Observed local image IDs when this set was fixed.
UCS_IMAGE_ID_UAV_BASE_GZ=sha256:7d9156a5887522092575f4676f1a4d2db2dcd1584d65f02ffecee4ce780758ab
UCS_IMAGE_ID_UAV_BASE_GZ_BMV2=sha256:118b52d3991d29ccb9dfa4191eca3629a10ba7efc95764fe54fdcc7cfe96be47
UCS_IMAGE_ID_GAZEBO_RUNTIME=sha256:a1b641c8f47457bf7c698aade25d431e207d022aa6603dd1abd8cfcc097cb737
UCS_IMAGE_ID_P4RUNTIME_SH=sha256:fd64e8efe0b384ce4b05970c3bdd1d4eef94f49ad4d6029f179655844128b380
